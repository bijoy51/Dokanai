# Optional API keys — app works fully without them.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ============================================================
# Local Docker Compose (`docker compose up --build`)
# ============================================================
# Copy this file to `.env` and edit the values, or just run with the
# defaults below for a first try. `.env` is gitignored.
#
# ADMIN_SECRET is shared by the ml-backend container (as ADMIN_SECRET)
# and the web container (as ML_ADMIN_SECRET) so the KV store accepts
# requests from the frontend. Both must match.
ADMIN_SECRET=local-dev-secret

# Signs the session cookie. Any non-empty string works locally;
# change before deploying anywhere real.
AUTH_SECRET=local-dev-auth-secret-change-me
